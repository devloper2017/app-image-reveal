{
  "name": "@nawazaideveloperr/image-reveal-spinner",
  "version": "0.1.2",
  "description": "Angular standalone image reveal spinner usable in Angular apps and as a Web Component",
  "license": "MIT",
  "type": "module",
  "main": "fesm2022/app-image-reveal.js",
  "module": "fesm2022/app-image-reveal.mjs",
  "types": "types/app-image-reveal.d.ts",
  "exports": {
    ".": {
      "types": "./types/app-image-reveal.d.ts",
      "import": "./fesm2022/app-image-reveal.mjs",
      "require": "./fesm2022/app-image-reveal.js"
    },
    "./elements": {
      "default": "./elements/main.js"
    }
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false
}